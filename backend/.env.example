# IDKit Backend Environment Variables
# Copy this file to .env and fill in the values

# Environment
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://idkit:idkit@localhost:5432/idkit

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=  # REQUIRED: Run python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OAuth - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AI Providers
OPENAI_API_KEY=
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# Storage - AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=idkit-media
S3_ENDPOINT_URL=http://localhost:9000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# GPU Providers (optional, for later)
VASTAI_API_KEY=
RUNPOD_API_KEY=
LAMBDA_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
