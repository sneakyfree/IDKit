{
  "name": "idkit-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test:ios:release": "detox build --configuration ios.sim.release && detox test --configuration ios.sim.release",
    "e2e:test:android:release": "detox build --configuration android.emu.release && detox test --configuration android.emu.release"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.3.0",
    "@react-navigation/native": "^6.1.9",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.5",
    "expo": "~50.0.0",
    "expo-av": "~13.10.0",
    "expo-camera": "~14.0.0",
    "expo-constants": "~15.4.5",
    "expo-device": "~5.9.3",
    "expo-file-system": "~16.0.5",
    "expo-font": "~11.10.2",
    "expo-haptics": "~12.8.1",
    "expo-image": "~1.10.4",
    "expo-image-picker": "~14.7.1",
    "expo-linking": "~6.2.2",
    "expo-media-library": "~15.9.1",
    "expo-notifications": "~0.27.5",
    "expo-router": "~3.4.0",
    "expo-secure-store": "~12.8.1",
    "expo-splash-screen": "~0.26.4",
    "expo-status-bar": "~1.11.1",
    "expo-system-ui": "~2.9.3",
    "expo-video-thumbnails": "~7.8.1",
    "expo-web-browser": "~12.8.2",
    "react": "18.2.0",
    "react-native": "0.83.1",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "detox": "^20.14.0",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^7.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.1",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
