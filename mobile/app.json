{
  "expo": {
    "name": "IDKit",
    "slug": "idkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "idkit",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idkit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "IDKit needs camera access to create content and AI twins.",
        "NSMicrophoneUsageDescription": "IDKit needs microphone access to record audio for podcasts and voice cloning.",
        "NSPhotoLibraryUsageDescription": "IDKit needs photo library access to upload content."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.idkit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow IDKit to access your camera for content creation."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow IDKit to access your photos for content uploads.",
          "savePhotosPermission": "Allow IDKit to save media to your gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow IDKit to access your photos for content uploads."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
